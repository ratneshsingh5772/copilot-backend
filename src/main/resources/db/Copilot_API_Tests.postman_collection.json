            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST011\",\n  \"name\": \"Karen White\",\n  \"phoneNumber\": \"+1-555-0111\",\n  \"currentPlanId\": 1,\n  \"tenureMonths\": 0,\n  \"billingCycleDate\": \"2026-03-05\"\n}"
            }
          }
        },
        {
          "name": "PUT Update Customer Plan",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/customers/CUST001",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST001\",\n  \"name\": \"Alice Johnson\",\n  \"phoneNumber\": \"+1-555-0101\",\n  \"currentPlanId\": 3,\n  \"tenureMonths\": 36,\n  \"billingCycleDate\": \"2026-03-15\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "4. Customer Usage",
      "item": [
        {
          "name": "GET Current Usage — CUST001 (near cap 4.2/5GB)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/usage/CUST001/current"
          }
        },
        {
          "name": "GET Current Usage — CUST003 (heavy roamer)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/usage/CUST003/current"
          }
        },
        {
          "name": "GET All Usage — CUST001",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/usage/CUST001/all"
          }
        },
        {
          "name": "POST Upsert Usage Record",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/usage",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST001\",\n  \"billingPeriodStart\": \"2026-03-15\",\n  \"dataUsedGb\": 4.85,\n  \"roamingUsedMb\": 0.00\n}"
            }
          }
        }
      ]
    },

    {
      "name": "5. AI Advisor — CORE FEATURE",
      "item": [
        {
          "name": "POST Advise — Data Booster (CUST001, near cap)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST001\",\n  \"prompt\": \"I have almost used all my data this month. What should I do?\"\n}"
            },
            "description": "Expected intent: DATA_BOOSTER. Gemini should recommend a booster or upgrade with pro-rated cost."
          }
        },
        {
          "name": "POST Advise — Travel Inquiry (CUST002)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST002\",\n  \"prompt\": \"I am travelling to the US next week for 3 weeks. What international plan should I get?\"\n}"
            },
            "description": "Expected intent: TRAVEL_INQUIRY. Should recommend US Roaming Pack or Global Roaming XL."
          }
        },
        {
          "name": "POST Advise — Plan Upgrade (CUST003)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST003\",\n  \"prompt\": \"I always run out of data and my roaming costs are very high. I need a better plan.\"\n}"
            },
            "description": "Expected intent: PLAN_UPGRADE. Customer on Premium 30GB with 18.4GB used and heavy roaming."
          }
        },
        {
          "name": "POST Advise — Billing Inquiry (CUST004)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST004\",\n  \"prompt\": \"Can you explain my bill this month? How much am I being charged?\"\n}"
            },
            "description": "Expected intent: BILLING_INQUIRY. Customer on Ultimate Unlimited."
          }
        },
        {
          "name": "POST Advise — Promo Inquiry (CUST006, 60m tenure)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST006\",\n  \"prompt\": \"I have been a customer for 5 years. Are there any special discounts or offers available for me?\"\n}"
            },
            "description": "Expected intent: PROMO_INQUIRY. Frank has 60m tenure — eligible for all 4 active promos including 25% 2-Year Champion Deal."
          }
        },
        {
          "name": "POST Advise — Plan Downgrade (CUST010)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST010\",\n  \"prompt\": \"I want to save money on my monthly bill. Can I switch to a cheaper plan?\"\n}"
            },
            "description": "Expected intent: PLAN_DOWNGRADE. James uses 38.9GB on Ultimate — AI should warn against downgrading."
          }
        },
        {
          "name": "POST Advise — New Customer (CUST005)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST005\",\n  \"prompt\": \"I just joined and I am not sure if I picked the right plan. What do you recommend?\"\n}"
            },
            "description": "Expected intent: GENERAL_INQUIRY. New customer on Starter 2GB with low usage."
          }
        },
        {
          "name": "POST Advise — Europe Travel (CUST008)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/advisor/recommend",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST008\",\n  \"prompt\": \"I travel to Europe and Asia frequently for business. I always run out of international data. What is the best roaming option?\"\n}"
            },
            "description": "Expected intent: TRAVEL_INQUIRY. Henry is a frequent traveller with 2048MB roaming usage."
          }
        }
      ]
    },

    {
      "name": "6. Plan Transactions",
