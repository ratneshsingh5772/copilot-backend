            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST001\",\n  \"newPlanId\": 3,\n  \"promoId\": null\n}"
