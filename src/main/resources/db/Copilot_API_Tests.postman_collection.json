            "method": "POST",
            "url": "{{baseUrl}}/api/v1/transactions/execute",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"CUST006\",\n  \"newPlanId\": 5,\n  \"promoId\": 4\n}"
            },
            "description": "Upgrades Frank (60m tenure) to Ultimate Unlimited with 25% loyalty discount."
          }
        }
