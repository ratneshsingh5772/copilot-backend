{
  "info": {
    "name": "Telecom Plan Advisor Copilot — Full API Test Suite",
    "description": "Complete test collection for the Self-Service Telecom Plan Advisor Copilot backend.\nBase URL: http://localhost:8081\n\nTest Order:\n1. Plans Catalog\n2. Promotions\n3. Customers\n4. Customer Usage\n5. AI Advisor (core feature)\n6. Plan Transactions\n7. Copilot Interactions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "customerId", "value": "CUST001" }
  ],
  "item": [

    {
      "name": "1. Plans Catalog",
      "item": [
        {
          "name": "GET All Plans",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/plans",
            "description": "Returns all 12 plans (5 base + 4 travel + 3 boosters)"
          }
        },
        {
          "name": "GET Plans by Type — BASE_PLAN",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/plans/type/BASE_PLAN"
          }
        },
        {
          "name": "GET Plans by Type — TRAVEL_ADD_ON",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/plans/type/TRAVEL_ADD_ON"
          }
        },
        {
          "name": "GET Plans by Type — DATA_BOOSTER",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/plans/type/DATA_BOOSTER"
          }
        },
        {
          "name": "GET Single Plan (Basic 5GB = ID 2)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/plans/2"
          }
        },
        {
          "name": "POST Create New Plan",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/plans",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planName\": \"Business Pro 50GB\",\n  \"planType\": \"BASE_PLAN\",\n  \"monthlyCost\": 89.99,\n  \"dataLimitGb\": 50,\n  \"description\": \"Enterprise-grade plan with 50 GB data, priority network and 24/7 support.\"\n}"
            }
          }
        },
        {
          "name": "PUT Update Plan",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/plans/2",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"planName\": \"Basic 5GB (Updated)\",\n  \"planType\": \"BASE_PLAN\",\n  \"monthlyCost\": 21.99,\n  \"dataLimitGb\": 5,\n  \"description\": \"Updated: 5 GB data, unlimited voice & SMS plus free streaming weekend.\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "2. Promotions",
      "item": [
        {
          "name": "GET All Promotions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/promotions"
          }
        },
        {
          "name": "GET Eligible Promos — tenure 36 months (CUST001)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/promotions/eligible/36",
            "description": "Should return Welcome, 6-month, 1-year, 2-year and Seasonal (5 promos)"
          }
        },
        {
          "name": "GET Eligible Promos — tenure 0 months (new customer)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/promotions/eligible/0",
            "description": "Should return only Welcome Offer and Seasonal Summer Sale (min_tenure=0)"
          }
        },
        {
          "name": "GET Single Promotion (ID 3)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/promotions/3"
          }
        },
        {
          "name": "POST Create Promotion",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/promotions",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"promoName\": \"Black Friday 35% Off\",\n  \"discountPercentage\": 35,\n  \"minTenureMonths\": 0,\n  \"isActive\": true\n}"
            }
          }
        }
      ]
    },

    {
      "name": "3. Customers",
      "item": [
        {
          "name": "GET All Customers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/customers"
          }
        },
        {
          "name": "GET Customer CUST001 (Alice — near data cap)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/customers/CUST001"
          }
        },
        {
          "name": "GET Customer CUST006 (Frank — 60m tenure, all promos eligible)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/customers/CUST006"
          }
        },
        {
          "name": "POST Create New Customer",
          "request": {
            "method": "POST",
