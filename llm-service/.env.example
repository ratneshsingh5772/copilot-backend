# Copy this file to .env and adjust values for your environment

# Ollama server URL (default: local install)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use — must be pulled first: ollama pull llama3.2
# Other options: mistral, phi3, llama3.1, gemma2
OLLAMA_MODEL=llama3.2

# Seconds to wait for Ollama to respond (increase for larger models / slow hardware)
OLLAMA_TIMEOUT_SECONDS=120

# FastAPI server settings
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
LOG_LEVEL=info
